{
  "name": "baskhedi-map-digitizer",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:smoke": "node _smoke_test.mjs",
    "electron:start": "electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "vite": "^5.2.0"
  },
  "dependencies": {
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "firebase": "^12.16.0"
  },
  "main": "main.js",
  "build": {
    "appId": "com.techsewak.mapdigitizer",
    "productName": "Map Digitizer",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js"
    ]
  }
}