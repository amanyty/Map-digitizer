rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Known app collections only — block arbitrary collection writes.
    function isAllowedCollection(collection) {
      return collection == 'maps'
        || collection == 'village_settings'
        || collection == 'features'
        || collection.matches('features_.*');
    }

    match /{collection}/{document=**} {
      // Public read for map viewing and routing (open village maps).
      allow read: if isAllowedCollection(collection);

      // Any authenticated editor may write known collections.
      // Tighten further with custom claims (e.g. admin) when multi-tenant.
      allow write: if isSignedIn() && isAllowedCollection(collection);
    }
  }
}
